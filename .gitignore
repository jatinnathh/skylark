# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
yolo*
data*
runs
# Next.js
.next/
out/
predictions.json
# YOLO datasets and outputs
backend/yolo_dataset/
backend/yolo_dataset_crop/
backend/yolo_dataset_full/
MODAL_URL.txt
# Images used for testing/validation
backend/testimage/
backend/valimage/

# Model weights - but allow our trained model
*.pt
*.pth
*.onnx
!backend/runs/gcp_pose/weights/best.pt

# Other runs output (training logs, checkpoints, etc) - but allow the weights folder
backend/runs/*
!backend/runs/gcp_pose/
!backend/runs/gcp_pose/weights/
!backend/runs/gcp_pose/weights/best.pt

# Jupyter
.ipynb_checkpoints/

# Python cache
__pycache__/
*.pyc
# production
/build
data
# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
